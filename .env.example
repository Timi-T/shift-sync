# =============================================================================
# ShiftSync — Environment Variables
# Copy this file to .env in the repo root and fill in the values.
# Individual apps (apps/api, apps/web) can also have their own .env files.
# NEVER commit .env to version control.
# =============================================================================

# --- Database (PostgreSQL) ---
# Docker (matches docker-compose.yml defaults — just run `docker compose up -d`):
DATABASE_URL="postgresql://shiftsync:shiftsync_dev@localhost:5432/shift_sync"
# Production: see your Railway / Neon project dashboard
# DATABASE_URL="postgresql://user:password@host:5432/shift_sync?sslmode=require"

# --- Redis ---
# Docker (matches docker-compose.yml defaults):
REDIS_URL="redis://localhost:6379"
# Production: see your Upstash / Railway Redis credentials
# REDIS_URL="rediss://user:password@host:6379"

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-long-random-secret-here"
JWT_EXPIRES_IN="7d"

# --- API Server ---
PORT=3001
NODE_ENV="development"
# Comma-separated list of allowed CORS origins
CORS_ORIGINS="http://localhost:3000"

# --- Web App ---
# Must match the Express API URL
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# --- Email (Simulated) ---
# Set EMAIL_ENABLED=true to send real emails via SMTP.
EMAIL_ENABLED="false"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@coastal-eats.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="ShiftSync <noreply@coastal-eats.com>"

# --- App Config ---
# Hours before a shift that a published schedule can no longer be edited.
SCHEDULE_EDIT_CUTOFF_HOURS="48"
# Hours before shift start that an unclaimed DROP request auto-expires.
DROP_REQUEST_EXPIRY_HOURS="24"
# Max concurrent pending swap/drop requests per staff member.
MAX_PENDING_SWAP_REQUESTS="3"
